# GitHub OAuth App (github.com/settings/developers)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Auth.js signing secret - generate with: openssl rand -base64 32
AUTH_SECRET=

# Postgres connection strings (Supabase: Project Settings -> Database -> Connection string)
# DATABASE_URL: transaction pooler (port 6543) - used by the app at runtime
# DIRECT_URL: session pooler or direct connection - used by drizzle-kit for migrations
DATABASE_URL=
DIRECT_URL=

# Server-only, used by the backend AI pipeline (never exposed to the Action or the browser)
GEMINI_API_KEY=
